#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/mouse.h>
#include <dt-bindings/zmk/outputs.h>
#include <dt-bindings/zmk/ext_power.h>
#include <behaviors/mouse_keys.dtsi>

#define BASE 0
#define COLEMAK_DH 1
#define NAV  2
#define NUM  3
#define SYM  4
#define FN   5
#define SYS  6

/ {
    behaviors {
        hml: homerow_mods_left {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <200>;
            quick-tap-ms = <175>;
            require-prior-idle-ms = <300>;
            flavor = "balanced";
            bindings = <&kp>, <&kp>;
        };
        
        hmr: homerow_mods_right {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <200>;
            quick-tap-ms = <175>;
            require-prior-idle-ms = <300>;
            flavor = "balanced";
            bindings = <&kp>, <&kp>;
        };
    };

    combos {
        compatible = "zmk,combos";

        /* Left Hand Horizontal Combos */
        combo_ds_save {
            timeout-ms = <50>;
            key-positions = <11 12>;
            bindings = <&kp LC(S)>;
        };

        combo_dfg_cut {
            timeout-ms = <50>;
            key-positions = <12 13 14>;
            bindings = <&kp LC(LS(F))>;
        };

        combo_zx_copy {
            timeout-ms = <50>;
            key-positions = <21 22>;
            bindings = <&kp LC(Z)>;
        };

        combo_xc_copy {
            timeout-ms = <50>;
            key-positions = <22 23>;
            bindings = <&kp LC(X)>;
        };

        combo_cv_undo {
            timeout-ms = <50>;
            key-positions = <23 24>;
            bindings = <&kp LC(C)>;
        };

        combo_vb_undo {
            timeout-ms = <50>;
            key-positions = <24 25>;
            bindings = <&kp LC(V)>;
        };

        /* Right Hand Horizontal Combos */
        combo_ui_bksp {
            timeout-ms = <50>;
            key-positions = <6 7>;
            bindings = <&kp BSPC>;
        };

        combo_io_del {
            timeout-ms = <50>;
            key-positions = <7 8>;
            bindings = <&kp DEL>;
        };

        combo_jk_lparen {
            timeout-ms = <50>;
            key-positions = <16 17>;
            bindings = <&kp LPAR>;
        };

        combo_kl_rparen {
            timeout-ms = <50>;
            key-positions = <17 18>;
            bindings = <&kp RPAR>;
        };

        combo_mcom_lbrack {
            timeout-ms = <50>;
            key-positions = <27 28>;
            bindings = <&kp LBKT>;
        };

        combo_comdot_rbrack {
            timeout-ms = <50>;
            key-positions = <28 29>;
            bindings = <&kp RBKT>;
        };

        /* Right Hand Vertical Combos */
        combo_jm_dash {
            timeout-ms = <50>;
            key-positions = <16 27>;
            bindings = <&kp MINUS>;
        };

        combo_hn_unds {
            timeout-ms = <50>;
            key-positions = <15 26>;
            bindings = <&kp UNDER>;
        };

        combo_kcom_semi {
            timeout-ms = <50>;
            key-positions = <17 28>;
            bindings = <&kp SEMI>;
        };

        combo_ldot_coln {
            timeout-ms = <50>;
            key-positions = <18 29>;
            bindings = <&kp COLON>;
        };

        combo_slash_ques {
            timeout-ms = <50>;
            key-positions = <19 30>;
            bindings = <&kp QUESTION>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        base_layer {
            bindings = <
                &kp Q           &kp W           &kp E           &kp R           &kp T               &kp Y           &kp U           &kp I           &kp O           &kp P
                &hml LGUI A     &hml LALT S     &hml LCTRL D    &hml LSHFT F    &kp G               &kp H           &hmr LSHFT J    &hmr LCTRL K    &hmr LALT L     &hmr RGUI SQT
                &kp Z           &kp X           &kp C           &kp V           &kp B               &kp N           &kp M           &kp COMMA       &kp DOT         &kp FSLH           
                                                &lt FN ESC      &lt NAV SPACE   &lt SYS TAB         &lt SYM ENTER   &lt NUM BSPC    &sk LSHFT
            >;
        };

        colemak_dh_layer {
            bindings = <
                &kp Q           &kp W           &kp F           &kp P           &kp G               &kp J           &kp L           &kp U           &kp Y           &kp SQT
                &hml LGUI A     &hml LALT R     &hml LCTRL S    &hml LSHFT T    &kp D               &kp H           &hmr LSHFT N    &hmr LCTRL E    &hmr LALT I     &hmr RGUI O
                &kp Z           &kp X           &kp C           &kp V           &kp B               &kp K           &kp M           &kp COMMA       &kp DOT         &kp FSLH           
                                                &lt FN ESC      &lt NAV SPACE   &lt SYS TAB         &lt SYM ENTER   &lt NUM BSPC    &sk LSHFT
            >;
        };

        nav_layer {
            bindings = <
                &trans          &trans          &trans          &trans          &trans              &trans          &msc SCRL_LEFT  &msc SCRL_DOWN  &msc SCRL_UP    &msc SCRL_RIGHT
                &kp LGUI        &kp LALT        &kp LCTRL       &kp LSHFT       &trans              &caps_word      &kp LEFT        &kp DOWN        &kp UP          &kp RIGHT
                &trans          &trans          &trans          &trans          &trans              &trans          &kp HOME        &kp PG_DN       &kp PG_UP       &kp END            
                                                &trans          &trans          &trans              &trans          &trans          &trans
            >;
        };

        num_layer {
            bindings = <
                &trans          &kp N7          &kp N8          &kp N9          &trans              &trans          &trans          &trans          &trans          &trans
                &kp LS(SEMI)    &kp N4          &kp N5          &kp N6          &kp EQUAL           &trans          &trans          &trans          &trans          &trans
                &kp GRAVE       &kp N1          &kp N2          &kp N3          &kp BSLH            &trans          &trans          &trans          &trans          &trans         
                                                &kp DOT         &kp N0          &kp MINUS           &trans          &trans          &trans 
            >;
        };

        sym_layer {
            bindings = <
                &trans          &kp LS(N7)      &kp LS(N8)      &kp LS(N9)      &trans              &trans          &trans          &trans          &trans          &trans
                &kp SEMI        &kp LS(N4)      &kp LS(N5)      &kp LS(N6)      &kp LS(EQUAL)       &trans          &trans          &trans          &trans          &trans
                &kp LS(GRAVE)   &kp LS(N1)      &kp LS(N2)      &kp LS(N3)      &kp LS(BSLH)        &trans          &trans          &trans          &trans          &trans         
                                                &trans          &kp SPACE       &trans              &trans          &trans          &trans
            >;
        };

        fn_layer {
            bindings = <
                &trans          &kp F7          &kp F8          &kp F9          &kp F12             &trans          &trans          &trans          &trans          &trans
                &trans          &kp F4          &kp F5          &kp F6          &kp F11             &trans          &trans          &trans          &trans          &trans
                &trans          &kp F1          &kp F2          &kp F3          &kp F10             &trans          &trans          &trans          &trans          &trans         
                                                &trans          &trans          &trans              &trans          &trans          &trans
            >;
        };

        sys_layer {
            bindings = <
                &bootloader     &to COLEMAK_DH  &to BASE        &trans          &bt BT_SEL 1        &trans          &trans          &kp C_BRI_UP    &kp C_BRI_DN    &trans
                &kp LG(N4)      &kp LG(N3)      &kp LG(N2)      &kp LG(N1)      &bt BT_SEL 2        &trans          &trans          &kp C_VOL_DN    &kp C_VOL_UP    &trans
                &trans          &trans          &trans          &trans          &bt BT_CLR          &trans          &trans          &trans          &trans          &trans         
                                                &trans          &trans          &trans              &kp C_MUTE      &kp C_PP        &kp C_STOP
            >;
        };


    };
};

&sk {
    release-after-ms = <2000>;
    quick-release;
};
